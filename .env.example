# Server
HOST=0.0.0.0
PORT=8899

# File cleanup
FILE_TTL_SECONDS=1800
CLEANUP_INTERVAL_SECONDS=300

# Rate limiting
RATE_LIMIT=30
RATE_WINDOW=60

# Download limits
MAX_CONCURRENT_DOWNLOADS=4

# Optional yt-dlp overrides
YTDLP_EXTRA_ARGS=
YOUTUBE_FALLBACK_ARGS=--extractor-args youtube:player_client=web_embedded
